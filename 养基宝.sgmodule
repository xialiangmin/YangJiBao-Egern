#!name=养基宝 Pro
#!desc=养基宝 VIP + 去广告
#!author=ChatGPT
#!homepage=https://ddgksf2013.top/

mitm:
  hostnames:
    - "*.yangjibao.com"

scriptings:
  - http_response:
      name: 养基宝VIP
      match: ^https?:\/\/.*yangjibao\.com\/.*\/(?:account|vip_info)
      body_required: true
      operation: |
        jsonjq '
        .data.vip_label = true |
        .data.vip_expiry_date = "2099-12-31" |
        .data.is_pay = true
        '

  - http_response:
      name: 去广告
      match: ^https?:\/\/.*yangjibao\.com\/unify_ad
      body_required: true
      operation: |
        jsonjq '
        .data = null
        '
